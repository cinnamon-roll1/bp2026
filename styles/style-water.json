{
  "version": 8,
  "name": "osmf-shortbread-water",
  "glyphs": "https://demotiles.maplibre.org/font/{fontstack}/{range}.pbf",
  "sources": {
    "osm": {
      "type": "vector",
      "url": "https://vector.openstreetmap.org/shortbread_v1/tilejson.json",
      "attribution": "<a href=\"https://www.openstreetmap.org/copyright\" target=\"_blank\" rel=\"noopener\">© OpenStreetMap contributors</a>"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#eef7fb"
      }
    },
    {
      "id": "ocean",
      "type": "fill",
      "source": "osm",
      "source-layer": "ocean",
      "paint": {
        "fill-color": "#bcdff5"
      }
    },
    {
      "id": "land-base",
      "type": "fill",
      "source": "osm",
      "source-layer": "land",
      "paint": {
        "fill-color": "#f5f1ea"
      }
    },
    {
      "id": "land-green",
      "type": "fill",
      "source": "osm",
      "source-layer": "land",
      "filter": [
        "match",
        ["get", "kind"],
        ["forest", "grass", "meadow", "park", "garden", "recreation_ground", "village_green", "allotments"],
        true,
        false
      ],
      "paint": {
        "fill-color": "#dbe9d5"
      }
    },
    {
      "id": "land-wet",
      "type": "fill",
      "source": "osm",
      "source-layer": "land",
      "filter": [
        "match",
        ["get", "kind"],
        ["wet_meadow", "marsh", "bog", "string_bog", "swamp", "reedbed", "saltmarsh", "tidalflat"],
        true,
        false
      ],
      "paint": {
        "fill-color": "#cfeaf7"
      }
    },
    {
      "id": "water-polygons",
      "type": "fill",
      "source": "osm",
      "source-layer": "water_polygons",
      "paint": {
        "fill-color": "#63b8e8"
      }
    },
    {
      "id": "water-lines",
      "type": "line",
      "source": "osm",
      "source-layer": "water_lines",
      "paint": {
        "line-color": "#1f84bf",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          7, 0.4,
          10, 1.2,
          14, 2.6
        ]
      }
    },
    {
      "id": "boundaries",
      "type": "line",
      "source": "osm",
      "source-layer": "boundaries",
      "paint": {
        "line-color": "#b9c5cc",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          3, 0.5,
          7, 0.8,
          10, 1.2
        ],
        "line-dasharray": [2, 2]
      }
    },
    {
      "id": "roads-major",
      "type": "line",
      "source": "osm",
      "source-layer": "streets",
      "filter": [
        "match",
        ["get", "kind"],
        ["motorway", "trunk", "primary", "secondary", "tertiary"],
        true,
        false
      ],
      "paint": {
        "line-color": "#fafafa",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          5, 0.4,
          8, 1.2,
          12, 3.2,
          15, 7
        ]
      }
    },
    {
      "id": "roads-local",
      "type": "line",
      "source": "osm",
      "source-layer": "streets",
      "filter": [
        "match",
        ["get", "kind"],
        ["unclassified", "residential", "living_street", "service"],
        true,
        false
      ],
      "paint": {
        "line-color": "#f1f5f9",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          11, 0.4,
          13, 1.1,
          15, 3.2
        ]
      }
    },
    {
      "id": "roads-paths",
      "type": "line",
      "source": "osm",
      "source-layer": "streets",
      "filter": [
        "match",
        ["get", "kind"],
        ["track", "footway", "path", "cycleway", "steps", "pedestrian"],
        true,
        false
      ],
      "paint": {
        "line-color": "#a7b4c0",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          12, 0.5,
          14, 1.6,
          16, 3.5
        ],
        "line-dasharray": [2, 1.2]
      }
    },
    {
      "id": "ferries",
      "type": "line",
      "source": "osm",
      "source-layer": "ferries",
      "paint": {
        "line-color": "#0d6fa8",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          8, 0.6,
          12, 1.5,
          15, 3
        ],
        "line-dasharray": [2, 1.5]
      }
    },
    {
      "id": "water-polygon-labels",
      "type": "symbol",
      "source": "osm",
      "source-layer": "water_polygons_labels",
      "layout": {
        "text-field": ["coalesce", ["get", "name"], ["get", "name_en"], ""],
        "text-font": ["Noto Sans Regular"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          6, 11,
          10, 13,
          14, 16
        ]
      },
      "paint": {
        "text-color": "#0f5d8c",
        "text-halo-color": "rgba(255,255,255,0.85)",
        "text-halo-width": 1
      }
    },
    {
      "id": "water-line-labels",
      "type": "symbol",
      "source": "osm",
      "source-layer": "water_lines_labels",
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name"], ["get", "name_en"], ""],
        "text-font": ["Noto Sans Regular"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          10, 11,
          14, 14
        ]
      },
      "paint": {
        "text-color": "#0f5d8c",
        "text-halo-color": "rgba(255,255,255,0.85)",
        "text-halo-width": 1
      }
    },
    {
      "id": "place-labels",
      "type": "symbol",
      "source": "osm",
      "source-layer": "place_labels",
      "layout": {
        "text-field": ["coalesce", ["get", "name"], ["get", "name_en"], ""],
        "text-font": ["Noto Sans Regular"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          5, 11,
          8, 12,
          12, 14
        ]
      },
      "paint": {
        "text-color": "#163247",
        "text-halo-color": "rgba(255,255,255,0.9)",
        "text-halo-width": 1.2
      }
    }
  ]
}