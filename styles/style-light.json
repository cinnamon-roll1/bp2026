{
  "version": 8,
  "name": "osmf-shortbread-light",
  "glyphs": "https://demotiles.maplibre.org/font/{fontstack}/{range}.pbf",
  "sources": {
    "osm": {
      "type": "vector",
      "url": "https://vector.openstreetmap.org/shortbread_v1/tilejson.json",
      "attribution": "<a href=\"https://www.openstreetmap.org/copyright\" target=\"_blank\" rel=\"noopener\">© OpenStreetMap contributors</a>"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#f3f4f6"
      }
    },
    {
      "id": "ocean",
      "type": "fill",
      "source": "osm",
      "source-layer": "ocean",
      "paint": {
        "fill-color": "#dbeafe"
      }
    },
    {
      "id": "land-base",
      "type": "fill",
      "source": "osm",
      "source-layer": "land",
      "paint": {
        "fill-color": "#ece6da"
      }
    },
    {
      "id": "land-green",
      "type": "fill",
      "source": "osm",
      "source-layer": "land",
      "filter": [
        "match",
        ["get", "kind"],
        ["forest", "grass", "meadow", "park", "garden", "recreation_ground", "village_green", "allotments"],
        true,
        false
      ],
      "paint": {
        "fill-color": "#d6e8c8"
      }
    },
    {
      "id": "land-wet",
      "type": "fill",
      "source": "osm",
      "source-layer": "land",
      "filter": [
        "match",
        ["get", "kind"],
        ["wet_meadow", "marsh", "bog", "string_bog", "swamp", "reedbed", "saltmarsh", "tidalflat"],
        true,
        false
      ],
      "paint": {
        "fill-color": "#d6edf6"
      }
    },
    {
      "id": "water-polygons",
      "type": "fill",
      "source": "osm",
      "source-layer": "water_polygons",
      "paint": {
        "fill-color": "#97cbe8"
      }
    },
    {
      "id": "water-lines",
      "type": "line",
      "source": "osm",
      "source-layer": "water_lines",
      "paint": {
        "line-color": "#4f93be",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          7, 0.4,
          10, 1.2,
          14, 2.6
        ]
      }
    },
    {
      "id": "boundaries",
      "type": "line",
      "source": "osm",
      "source-layer": "boundaries",
      "paint": {
        "line-color": "#b6aa96",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          3, 0.5,
          7, 0.8,
          10, 1.2
        ],
        "line-dasharray": [2, 2]
      }
    },
    {
      "id": "roads-major",
      "type": "line",
      "source": "osm",
      "source-layer": "streets",
      "filter": [
        "match",
        ["get", "kind"],
        ["motorway", "trunk", "primary", "secondary", "tertiary"],
        true,
        false
      ],
      "paint": {
        "line-color": "#ffffff",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          5, 0.4,
          8, 1.2,
          12, 3.2,
          15, 7
        ]
      }
    },
    {
      "id": "roads-local",
      "type": "line",
      "source": "osm",
      "source-layer": "streets",
      "filter": [
        "match",
        ["get", "kind"],
        ["unclassified", "residential", "living_street", "service"],
        true,
        false
      ],
      "paint": {
        "line-color": "#f7f7f7",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          11, 0.4,
          13, 1.1,
          15, 3.2
        ]
      }
    },
    {
      "id": "roads-paths",
      "type": "line",
      "source": "osm",
      "source-layer": "streets",
      "filter": [
        "match",
        ["get", "kind"],
        ["track", "footway", "path", "cycleway", "steps", "pedestrian"],
        true,
        false
      ],
      "paint": {
        "line-color": "#b7803f",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          12, 0.5,
          14, 1.6,
          16, 3.5
        ],
        "line-dasharray": [1, 0]
      }
    },
    {
      "id": "ferries",
      "type": "line",
      "source": "osm",
      "source-layer": "ferries",
      "paint": {
        "line-color": "#2f8fc1",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          8, 0.6,
          12, 1.5,
          15, 3
        ],
        "line-dasharray": [2, 1.5]
      }
    },
    {
      "id": "buildings",
      "type": "fill",
      "source": "osm",
      "source-layer": "buildings",
      "paint": {
        "fill-color": "#d7c7b8",
        "fill-outline-color": "rgba(0,0,0,0.08)"
      }
    },
    {
      "id": "street-labels",
      "type": "symbol",
      "source": "osm",
      "source-layer": "street_labels",
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name"], ["get", "ref"], ""],
        "text-font": ["Noto Sans Regular"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          12, 10,
          15, 13
        ]
      },
      "paint": {
        "text-color": "#586273",
        "text-halo-color": "rgba(255,255,255,0.85)",
        "text-halo-width": 1
      }
    },
    {
      "id": "place-labels",
      "type": "symbol",
      "source": "osm",
      "source-layer": "place_labels",
      "layout": {
        "text-field": ["coalesce", ["get", "name"], ["get", "name_en"], ""],
        "text-font": ["Noto Sans Regular"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          5, 11,
          8, 12,
          12, 14
        ]
      },
      "paint": {
        "text-color": "#24313d",
        "text-halo-color": "rgba(255,255,255,0.9)",
        "text-halo-width": 1.2
      }
    }
  ]
}